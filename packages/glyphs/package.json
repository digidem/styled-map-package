{
  "name": "smp-noto-glyphs",
  "version": "1.0.0-pre.0",
  "description": "Pre-built Noto Sans SDF glyph PBFs (80+ scripts) for MapLibre-compatible map servers",
  "type": "module",
  "main": "./lib/noto.js",
  "types": "./dist/noto.d.ts",
  "exports": {
    ".": {
      "types": "./dist/noto.d.ts",
      "default": "./lib/noto.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "dist",
    "fixtures"
  ],
  "scripts": {
    "test": "vitest run",
    "prepack": "npm run build",
    "build": "tsc -p tsconfig.build.json",
    "types": "tsc"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "maplibre",
    "glyphs",
    "noto-sans",
    "sdf",
    "pbf",
    "fonts",
    "fallback"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digidem/styled-map-package.git",
    "directory": "packages/glyphs"
  }
}
