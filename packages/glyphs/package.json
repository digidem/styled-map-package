{
  "name": "smp-noto-glyphs",
  "version": "0.0.0",
  "description": "Pre-built Noto Sans SDF glyph PBFs (80+ scripts) for MapLibre-compatible map servers",
  "type": "module",
  "main": "./dist/noto.cjs",
  "module": "./dist/noto.js",
  "types": "./dist/noto.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/noto.d.ts",
        "default": "./dist/noto.js"
      },
      "require": {
        "types": "./dist/noto.d.cts",
        "default": "./dist/noto.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "fixtures"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "tsup",
    "types": "tsc"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "maplibre",
    "glyphs",
    "noto-sans",
    "sdf",
    "pbf",
    "fonts",
    "fallback"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digidem/styled-map-package.git",
    "directory": "packages/glyphs"
  }
}
